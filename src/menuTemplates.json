        { "MenuPath": "File>&New"  , "QuickKey": "Ctrl+N", "ToolTip": "Create a new file" },
        { "MenuPath": "File>&Open" , "QuickKey": "Ctrl+O", "ToolTip": "Open an existing file" },
        { "MenuPath": "File>&Close", "QuickKey": "Ctrl+W", "SeparatorBefore": true, "ToolTip": "Close the current file" },
