        { "MenuPath": "File>Recent &Files"  , "QuickKey": "Ctrl+Shift+O", "ToolTip": "Open a recently used file" },
        { "MenuPath": "File>Save"   , "QuickKey": "Ctrl+S", "SeparatorBefore": true, "ToolTip": "Save the current file" },
        { "MenuPath": "File>Preferences", "ToolTip": "Open preferences configuration", "SeparatorBefore": true },
        { "MenuPath": "File>E&xit"      , "QuickKey": "Alt+F4", "SeparatorBefore": true, "ToolTip": "Exit the application" },
